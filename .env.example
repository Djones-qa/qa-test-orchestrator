# Server
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qa_orchestrator?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
AUTH_SECRET=your-secret-key-here

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Worker Configuration
WORKER_CONCURRENCY=5
QUEUE_MAX_DEPTH=100

# Data Retention
RETENTION_DAYS=90

# Notification Thresholds
PASS_RATE_THRESHOLD=80
